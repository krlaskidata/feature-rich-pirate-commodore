# ⚓ The Cursed Commodore - Environment Configuration Example

# REQUIRED: Discord Bot Token
# Get from: https://discord.com/developers/applications
PIRATBOT_TOKEN=your_bot_token_here

# OPTIONAL: Bot Owner IDs (comma-separated)
# For permission-restricted commands
PIRATBOT_OWNERS=user_id_1,user_id_2

# OPTIONAL: Allowed Guild IDs (comma-separated)
# Whitelist servers where the bot should operate
PIRATBOT_ALLOWED_GUILDS=guild_id_1,guild_id_2

# OPTIONAL: Authorized User IDs (comma-separated)
# Additional users with special permissions
PIRATBOT_AUTHORIZED_USERS=user_id_1,user_id_2

# OPTIONAL: Server Invite Codes (comma-separated)
# For invite export functionality
PIRATBOT_INVITES=invite_code_1,invite_code_2

# OPTIONAL: Enable Server Invites Export
# Set to "true" to enable, default is false (disabled for security)
PIRATBOT_ENABLE_SERVER_INVITES_EXPORT=false

# ========================================
# SETUP INSTRUCTIONS
# ========================================
# 1. Copy this file to .env in the same directory
# 2. Replace "your_bot_token_here" with your actual bot token
# 3. Run: dotnet run
#
# ⚠️ IMPORTANT: Never commit .env to version control!
# ⚠️ The .gitignore file is configured to exclude .env files
# ========================================
